# -----------------------------------------------------------------------
# Environment variables for the AI-Powered Sentiment Analysis app.
#
# Copy this file to a new file named ".env" in the project root and fill
# in your real values. Never commit your actual .env file to version
# control -- only this .env.example template should be tracked by git.
# -----------------------------------------------------------------------

# Which AI provider to use for sentiment analysis.
# Currently supported: "gemini"
# (Future providers like "openai" or "claude" can be added in analyzer.py)
AI_PROVIDER=gemini

# Your Google Gemini API key.
# Get one for free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
